# Server Port
PORT=9999

# API Token for authentication (optional)
# API_TOKEN=your-secret-token

# Rate limit per minute (default: 60)
# RATE_LIMIT=60

# Request body size limit (default: 1mb)
# BODY_LIMIT=1mb

# SQLite Database Path (default: ./webhook-history.db)
# DB_PATH=./webhook-history.db

# History retention days (default: 30)
# HISTORY_DAYS=30

# History max size in MB (default: 100)
# HISTORY_MAX_SIZE_MB=100

# Redis Configuration (for rate limiting)
# Redis Host (default: localhost)
# REDIS_HOST=redis

# Redis Port (default: 6379)
# REDIS_PORT=6379

# Redis Password (optional)
# REDIS_PASSWORD=

# Redis DB number (default: 0)
# REDIS_DB=0

# Rate limit window in seconds (default: 60)
# RATE_LIMIT_WINDOW=60

# Webhook Forwarding Configuration
# Enable webhook forwarding (default: false)
# FORWARD_ENABLED=false

# Forward endpoints (comma separated URLs)
# FORWARD_ENDPOINTS=https://example.com/webhook,https://another.com/hook

# Forward timeout in ms (default: 5000)
# FORWARD_TIMEOUT=5000

# Forward auth header value (optional)
# FORWARD_AUTH_HEADER=Bearer your-token

# Logging Configuration
# Log level: trace, debug, info, warn, error, fatal (default: info)
# LOG_LEVEL=info

# Log directory (default: ./logs)
# LOG_DIR=./logs

# Enable console log output (default: true)
# ENABLE_CONSOLE_LOG=true

# Enable file log output (default: true)
# ENABLE_FILE_LOG=true

# Max log files to keep (default: 7)
# LOG_MAX_FILES=7

# Max log file size (default: 100m)
# LOG_MAX_SIZE=100m

# IP Whitelist (comma separated, leave empty to allow all, use * for any)
# ALLOWED_IPS=127.0.0.1,::1

# Alert filter labels (comma separated)
# FILTER_LABELS=severity=critical,team=ops

# Filter mode: 'allow' (only match labels) or 'block' (exclude match labels)
# FILTER_MODE=allow

# Alert Sound Configuration
# Available sounds (located in /System/Library/Sounds):
# - Basso
# - Blow
# - Bottle
# - Frog
# - Funk
# - Glass (Default)
# - Hero
# - Morse
# - Ping
# - Pop
# - Purr
# - Sosumi
# - Submarine
# - Tink

ALERT_SOUND=Glass

# Volume (0.0 to 1.0, and >1 for amplification)
# 0.1 = Low, 0.5 = Medium, 1.0 = Normal, 2.0 = Double
ALERT_VOLUME=0.1
